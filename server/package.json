{
  "name": "tailcall-signaling-server",
  "version": "0.1.0",
  "description": "TailCall signaling server - WebSocket relay + session management",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src src/index.js | pino-pretty",
    "test": "vitest run --exclude test/e2e.test.js",
    "test:watch": "vitest --exclude test/e2e.test.js",
    "test:e2e": "node --no-warnings test/e2e-runner.js",
    "test:all": "vitest run --exclude test/e2e.test.js && node --no-warnings test/e2e-runner.js"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true,
  "dependencies": {
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "vitest": "^4.1.2"
  }
}
